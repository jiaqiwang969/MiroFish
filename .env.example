# LLM API配置（支持 OpenAI SDK 格式的任意 LLM API）
# 本地部署推荐直接填写你自己的 OpenAI-compatible 服务
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://your-openai-compatible-endpoint/v1
LLM_MODEL_NAME=gpt-5.4-mini

# ===== 图谱后端配置（推荐 Graphiti 本地模式）=====
GRAPH_BACKEND=graphiti
GRAPHITI_SERVICE_URL=http://127.0.0.1:8011
GRAPHITI_REQUEST_TIMEOUT_SECONDS=300
GRAPHITI_BUILD_BATCH_SIZE=2

# ===== Graphiti sidecar 本地配置（建议放到 graphiti_service/.env）=====
# 首次启动会下载本地 embedding 模型 BAAI/bge-m3，缓存约 2.4GB
# GRAPHITI_DB_PATH=./graphiti_service/data/graphiti.kuzu
# GRAPHITI_EMBEDDING_MODEL=BAAI/bge-m3

# ===== Zep 旧模式（可选，兼容保留）=====
# GRAPH_BACKEND=zep
# ZEP_API_KEY=your_zep_api_key_here

# ===== 加速 LLM 配置（可选）=====
# 注意如果不使用加速配置，env文件中就不要出现下面的配置项
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here
